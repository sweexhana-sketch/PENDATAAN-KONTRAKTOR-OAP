{
    "version": 2,
    "installCommand": "npm install --legacy-peer-deps",
    "builds": [
        {
            "src": "api/index.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.ts"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.ts"
        }
    ]
}