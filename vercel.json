{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "node node_modules/@react-router/dev/bin.js build --no-typecheck",
  "framework": "vite",
  "outputDirectory": "build/client",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}