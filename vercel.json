{
    "version": 2,
    "framework": null,
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "outputDirectory": "build/client",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/$1"
        }
    ],
    "redirects": []
}